# BookKeeper AI — environment configuration.
# The desktop app runs fully offline with NO env vars set. These enable optional integrations.

# --- AI error correction (optional; offline deterministic fallback if unset) ---
ANTHROPIC_API_KEY="your-anthropic-api-key-here"

# --- Auth session signing (optional; a per-company secret is auto-generated if unset) ---
# BKA_AUTH_SECRET="generate-a-long-random-string"

# --- Local data directory override (Electron sets this per company file automatically) ---
# BKA_DATA_DIR="C:\\path\\to\\company-data"

# --- Live bank feeds via Plaid (optional; built-in demo feed works without this) ---
# PLAID_CLIENT_ID="..."
# PLAID_SECRET="..."
# PLAID_ENV="sandbox"   # sandbox | development | production

# --- Email invoices/statements via SMTP (optional) ---
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USER="you@example.com"
# SMTP_PASS="your-smtp-password"
# SMTP_FROM="BookKeeper AI <you@example.com>"

# --- Code signing for desktop installers (optional; see SIGNING.md) ---
# CSC_LINK="build\\code-sign.pfx"
# CSC_KEY_PASSWORD="your-cert-password"

# NOTE: The legacy cloud DATABASE_URL / NEXTAUTH_* vars are no longer used — the app uses a local
# embedded PGlite database. Kept here only for reference if deploying the web build to a server.
